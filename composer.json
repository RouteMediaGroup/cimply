    "version": "4.0.1",
    "keywords": ["framework", "business", "automation", "php"],
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "RouteMedia - Digital Solutions",
            "email": "direkt@route-media.info",
